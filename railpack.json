{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "php": "8.4",
    "node": "20"
  },
  "deploy": {
    "startCommand": "php artisan config:cache && php artisan route:cache && php artisan view:cache && php artisan migrate --force && php artisan storage:link && php -S 0.0.0.0:$PORT -t public public/router.php"
  },
  "steps": {
    "build": {
      "commands": ["npm install --include=dev", "npm run build"],
      "outputs": ["public/build"]
    }
  },
  "buildAptPackages": [
    "bison",
    "re2c",
    "pkg-config",
    "libcurl4-openssl-dev",
    "libssl-dev",
    "libxml2-dev",
    "libzip-dev",
    "libicu-dev",
    "libonig-dev",
    "libsqlite3-dev",
    "libpng-dev",
    "libjpeg-dev",
    "libgd-dev",
    "libfreetype6-dev",
    "libwebp-dev",
    "libxpm-dev",
    "libsodium-dev",
    "libreadline-dev",
    "zlib1g-dev",
    "libbz2-dev",
    "libgmp-dev",
    "libxslt1-dev",
    "libpq-dev"
  ],
  "aptPackages": [
    "libpq5",
    "libicu72",
    "libsodium23",
    "libzip4",
    "libonig5",
    "libgd3",
    "libfreetype6",
    "libwebp7",
    "libcurl4",
    "libxml2",
    "libreadline8",
    "libgmp10",
    "libxslt1.1"
  ]
}
