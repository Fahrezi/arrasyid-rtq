{
  "permissions": {
    "allow": [
      "Bash(xargs cat)",
      "Bash(mysql -u root -p'0nline_kan_Arrasyiid' arrasyid_rtq -e \"DESCRIBE users;\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$j = [Console]::In.ReadToEnd() | ConvertFrom-Json; $f = $j.tool_input.file_path; if ($f) { npx --prefix 'd:/laravel_project/arrasyid-rtq' prettier --write \"$f\" --ignore-unknown 2>$null }",
            "shell": "powershell",
            "statusMessage": "Running Prettier..."
          }
        ]
      }
    ]
  }
}
